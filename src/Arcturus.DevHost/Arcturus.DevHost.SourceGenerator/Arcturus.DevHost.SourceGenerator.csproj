<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>netstandard2.0</TargetFramework>
		<TargetFrameworks></TargetFrameworks>

		<PackageId>Arcturus.DevHost.SourceGenerator</PackageId>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageTags>devhost,arcturus</PackageTags>
		<Description>Roslyn source generator that provides DevHost scaffolding and utilities for Arcturus-based .NET projects.</Description>
		<PackageIcon>nuget.png</PackageIcon>
		
		<EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
		<IsRoslynComponent>true</IsRoslynComponent>

		<!-- Package the generator as an analyzer -->
		<IncludeBuildOutput>false</IncludeBuildOutput>
		<DevelopmentDependency>true</DevelopmentDependency>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.3.0" PrivateAssets="all" />
		<PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="5.3.0" PrivateAssets="all" />
	</ItemGroup>

	<!-- Include the generator DLL in the NuGet package analyzers folder -->
	<ItemGroup>
		<None Include="$(OutputPath)\$(AssemblyName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
	</ItemGroup>

	<ItemGroup>
		<None Include="docs\README.md" Pack="true" PackagePath="\" />
		<None Include="..\..\..\assets\nuget.png" Pack="true" PackagePath="\" />
	</ItemGroup>
</Project>
